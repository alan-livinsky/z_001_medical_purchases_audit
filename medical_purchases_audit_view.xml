            <field name="name">Auditoria compras de medicamentos</field>
            <field name="res_model">gnuhealth.medical.purchase.audit</field>
            <field name="domain" eval="[('state', '=', 'signed_by_purchases')]" pyson="1"/>
        </record>

        <record model="ir.action.act_window" id="act_medical_purchase_package">
            <field name="name">Paquetes de Auditoria</field>
            <field name="res_model">gnuhealth.medication.purchase.package</field>
        </record>

