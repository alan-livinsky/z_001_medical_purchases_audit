            <field name="act_window" ref="act_medical_purchase_audit_review"/>
        </record>

        <menuitem name="Compras Medicas"
                  parent="health.gnuhealth_menu"
                  id="menu_medical_purchase_audit_root"
                  sequence="60"/>

        <menuitem name="Borradores de Compras"
                  parent="menu_medical_purchase_audit_root"
                  id="menu_medical_purchase_audit"
                  sequence="10"
                  action="act_medical_purchase_audit"/>

        <menuitem name="Auditoria compras de medicamentos"
                  parent="z_001_prescription_audit.menu_prescription_audit_v3"
                  id="menu_medical_purchase_audit_review"
                  sequence="20"
                  action="act_medical_purchase_audit_review"/>

        <record model="ir.ui.menu-res.group" id="menu_medical_purchase_audit_root_group_purchase">
